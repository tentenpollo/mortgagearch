# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mortgagearch"

# Supabase (get from: https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
