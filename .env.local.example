# Vercel Blob Storage (get from: https://vercel.com/dashboard/stores)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxx"

# App URL (for generating upload links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
